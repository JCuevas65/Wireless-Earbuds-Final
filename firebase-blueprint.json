{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Customer order containing purchased items and shipping info",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who placed the order" },
        "items": { "type": "array", "description": "List of ordered items" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "shippingAddress": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["userId", "items", "total", "createdAt"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "Individual product purchase record",
      "type": "object",
      "properties": {
        "productName": { "type": "string" },
        "price": { "type": "number" },
        "transactionId": { "type": "string" },
        "purchasedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productName", "price", "transactionId", "purchasedAt"]
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "/users/{userId}/purchases/{purchaseId}": {
      "schema": "Purchase",
      "description": "User specific purchase history"
    }
  }
}
