rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net (Pillar 0)
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Context-Aware Helper Primitives (Pillar 3 & 4)
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // 1. Orders Collection (Pillar 1 & 2)
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.keys().hasAll(['userId', 'items', 'total', 'shippingAddress', 'email', 'paymentMethod', 'transactionId', 'createdAt']) &&
               data.keys().size() == 8 &&
               data.userId is string && 
               data.userId == request.auth.uid &&
               data.items is list &&
               data.items.size() > 0 &&
               data.total is number &&
               data.total >= 0 &&
               data.shippingAddress is string &&
               data.shippingAddress.size() <= 500 &&
               data.email is string &&
               data.email.size() <= 256 &&
               data.paymentMethod is string &&
               data.transactionId is string &&
               data.createdAt == request.time;
      }

      // Pillar 3: Path Variable Hardening
      allow create: if isSignedIn() && isValidOrder(incoming()) && isValidId(orderId);
      
      // Pillar 8: Secure List Queries (Explicit checks)
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 2. User Profiles & Purchases (Pillar 6: PII Isolation via Split Path)
    match /users/{userId} {
      // Basic profile read
      allow read: if isOwner(userId);
      
      match /purchases/{purchaseId} {
        function isValidPurchase(data) {
          return data.keys().hasAll(['productName', 'price', 'transactionId', 'purchasedAt']) &&
                 data.keys().size() == 4 &&
                 data.productName is string &&
                 data.productName.size() <= 200 &&
                 data.price is number &&
                 data.transactionId is string &&
                 data.purchasedAt == request.time;
        }

        allow create: if isOwner(userId) && isValidId(userId) && isValidPurchase(incoming()) && isValidId(purchaseId);
        allow read: if isOwner(userId);
      }
    }
  }
}
